  "properties": {
    "schema_version": {"type": "string"},
    "case_id": {"type": "string"},
    "best_slice_index": {"type": "integer", "minimum": 0},
    "uca_angle_deg": {"type": "number"},
    "manual_review_required": {"type": "boolean"}
  }
}
