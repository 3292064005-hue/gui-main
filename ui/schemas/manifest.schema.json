{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manifest.schema.json",
  "title": "SessionManifest",
  "type": "object",
  "required": [
    "experiment_id",
    "session_id",
    "config_snapshot",
    "scan_plan_hash",
    "artifact_registry",
    "processing_steps"
  ],
  "properties": {
    "experiment_id": {"type": "string"},
    "session_id": {"type": "string"},
    "created_at": {"type": "string"},
    "config_snapshot": {"type": "object"},
    "scan_plan_hash": {"type": "string"},
    "patient_registration_hash": {"type": "string"},
    "localization_readiness_hash": {"type": "string"},
    "calibration_bundle_hash": {"type": "string"},
    "localization_freeze_hash": {"type": "string"},
    "manual_adjustment_hash": {"type": "string"},
    "source_frame_set_hash": {"type": "string"},
    "guidance_version": {"type": "string"},
    "guidance_mode": {"type": "string"},
    "guidance_source_type": {"type": "string"},
    "artifact_registry": {"type": "object"},
    "processing_steps": {"type": "array", "items": {"type": "object"}},
    "guidance_processing_steps": {"type": "array", "items": {"type": "object"}},
    "algorithm_registry": {"type": "object"},
    "guidance_algorithm_registry": {"type": "object"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "alarms_summary": {"type": "object"},
    "device_readiness": {"type": "object"},
    "safety_thresholds": {"type": "object"},
    "device_health_snapshot": {"type": "object"},
    "artifacts": {"type": "object"},
    "robot_profile": {"type": "object"},
    "patient_registration": {"type": "object"},
    "localization_readiness": {"type": "object"},
    "calibration_bundle": {"type": "object"},
    "localization_freeze": {"type": "object"},
    "manual_adjustment": {"type": "object"},
    "source_frame_set": {"type": "object"},
    "scan_protocol": {"type": "object"}
  }
}
