{
  "$id": "back_roi.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["center_y_mm", "length_mm", "height_mm", "confidence", "bounding_box_px"],
  "properties": {
    "center_y_mm": {"type": "number"},
    "length_mm": {"type": "number", "exclusiveMinimum": 0},
    "height_mm": {"type": "number", "exclusiveMinimum": 0},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "bounding_box_px": {
      "type": "object",
      "required": ["x0", "x1", "y0", "y1"],
      "properties": {
        "x0": {"type": "integer", "minimum": 0},
        "x1": {"type": "integer", "minimum": 0},
        "y0": {"type": "integer", "minimum": 0},
        "y1": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
