{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AssessmentSummary",
  "type": "object",
  "required": [
    "session_id",
    "method_version",
    "cobb_angle_deg",
    "confidence",
    "requires_manual_review",
    "coordinate_frame",
    "evidence_refs"
  ],
