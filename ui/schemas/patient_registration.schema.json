{
  "$id": "patient_registration.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PatientGuidanceRegistrationContract",
  "type": "object",
  "required": [
    "schema_version",
    "registration_id",
    "generated_at",
    "status",
    "role",
    "guidance_mode",
    "execution_authority",
    "source_type",
    "patient_frame",
    "scan_corridor",
    "freeze_ready",
    "registration_hash"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "2.0"},
    "registration_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string"},
    "status": {"type": "string", "enum": ["READY", "REVIEW_REQUIRED", "BLOCKED"]},
    "role": {"type": "string", "const": "guidance_only"},
    "guidance_mode": {"type": "string", "const": "pre_scan_guidance"},
    "execution_authority": {"type": "string", "const": "planner_after_freeze"},
    "source_type": {"type": "string", "enum": ["camera_only", "camera_ultrasound_fusion", "manual_override", "fallback_simulated"]},
    "source": {"type": "string"},
    "camera_device_id": {"type": "string", "minLength": 1},
    "camera_frame_refs": {"type": "array", "items": {"type": "string"}},
    "camera_intrinsics_hash": {"type": "string"},
    "camera_to_base_hash": {"type": "string"},
    "probe_tcp_hash": {"type": "string"},
    "temporal_sync_hash": {"type": "string"},
    "algorithm_bundle_hash": {"type": "string"},
    "back_roi": {"$ref": "back_roi.schema.json"},
    "midline_polyline": {"$ref": "midline_polyline.schema.json"},
    "landmarks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "x", "y", "z"],
        "properties": {
          "name": {"type": "string"},
          "x": {"type": "number"},
          "y": {"type": "number"},
          "z": {"type": "number"}
        },
        "additionalProperties": false
      }
    },
    "body_surface": {"$ref": "body_surface.schema.json"},
    "camera_observations": {"type": "object"},
    "confidence_breakdown": {"type": "object"},
    "quality_metrics": {"type": "object"},
    "patient_frame": {"type": "object"},
    "scan_corridor": {"type": "object"},
    "guidance_targets": {"$ref": "guidance_targets.schema.json"},
    "usable_segments": {"type": "array", "items": {"type": "integer", "minimum": 1}},
    "registration_covariance": {"type": "object"},
    "manual_adjustments": {"type": "array"},
    "freeze_ready": {"type": "boolean"},
    "blocking_reasons": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "review_approval": {"type": "object"},
    "recommended_action": {"type": "string", "enum": ["freeze", "freeze_after_review", "review", "retry_capture", "recalibrate"]},
    "artifact_refs": {"type": "array", "items": {"type": "string"}},
    "processing_step_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "notes": {"type": "array", "items": {"type": "string"}},
    "registration_quality": {"type": "object"},
    "registration_hash": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
