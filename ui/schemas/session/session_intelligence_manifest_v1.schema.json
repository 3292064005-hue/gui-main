{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Session intelligence manifest v1",
  "type": "object",
  "required": ["generated_at", "session_id", "schema", "products"],
  "properties": {
    "generated_at": {"type": "string"},
    "session_id": {"type": "string"},
    "schema": {"type": "string"},
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "product",
          "output_artifact",
          "dependencies",
          "retryable",
          "performance_budget_ms",
          "owner_domain",
          "materialization_phase",
          "read_policy",
          "stale_policy",
          "materialized"
        ],
        "properties": {
          "product": {"type": "string"},
          "output_artifact": {"type": "string"},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "retryable": {"type": "boolean"},
          "performance_budget_ms": {"type": "integer"},
          "owner_domain": {"type": "string"},
          "materialization_phase": {"type": "string"},
          "read_policy": {"type": "string"},
          "stale_policy": {"type": "string"},
          "materialized": {"type": "boolean"}
        }
      }
    }
  }
}
