    "session_id",
    "session_dir",
    "build_id",
    "profile",
    "robot_family_descriptor",
    "status",
    "required_evidence",
    "controller_log_summary",
    "phase_transition_trace",
    "rt_jitter_or_packet_loss_snapshot",
    "final_verdict_trace",
    "latest_observation",
    "ledger_hash"
