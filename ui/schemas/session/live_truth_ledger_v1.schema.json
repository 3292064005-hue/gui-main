  "properties": {
    "ledger_kind": {"const": "live_truth_ledger"},
    "session_id": {"type": "string"},
    "session_dir": {"type": "string"},
    "build_id": {"type": "string"},
    "profile": {"type": "object"},
    "robot_family_descriptor": {"type": "object"},
    "status": {"type": "string"},
    "required_evidence": {"type": "array", "items": {"type": "string"}},
    "controller_log_summary": {"type": "object"},
    "phase_transition_trace": {"type": "object"},
    "rt_jitter_or_packet_loss_snapshot": {"type": "object"},
    "final_verdict_trace": {"type": "object"},
