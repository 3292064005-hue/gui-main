# Canonical RT host contract for spine-cpp-core.
# This file is an operator-visible deployment artifact and must stay aligned
# with configs/systemd/spine-cpp-core.service, cpp_robot_core/src/rt_host_bootstrap.cpp,
# and doctor/runtime readiness checks.
SPINE_RT_HOST_CONTRACT_VERSION=1
SPINE_RT_HOST_CONTRACT_LABEL=research_clinical_mainline
SPINE_RT_FIXED_HOST_ID=spine-rt-workstation-01
SPINE_RT_SCHED_POLICY=fifo
SPINE_RT_SCHED_PRIORITY=90
SPINE_RT_CPU_SET=0,1
SPINE_RT_REQUIRE_SCHEDULER=1
SPINE_RT_REQUIRE_AFFINITY=1
SPINE_RT_REQUIRE_MEMORY_LOCK=1
SPINE_RT_REQUIRE_PREEMPT_RT=1
SPINE_RT_REQUIRE_FIXED_HOST_ID=1
